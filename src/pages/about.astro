---
import MainLayout from "../layouts/MainLayout.astro";
import Section from "../components/Section.astro";
import Grid from "../components/Grid.astro";
import Card from "../components/Card.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { Waypoints, Zap, FileBracesCorner } from "lucide-react";
import TechStackGrid from "../components/TechStackGrid.astro";

const values = [
  {
    icon: Waypoints,
    title: "Portfolio Website",
    description:
      "This website is built with Astro, DaisyUI, and TypeScript, with a strong focus on responsive design, clean structure, and a consistent component system.",
  },
  {
    icon: Zap,
    title: "What I'm Working Towards",
    description:
      "I want to become a well-rounded full-stack developer. I aim to design and build applications from the initial idea all the way to deployment. I don't just want things to function. I want to build them cleanly and sustainably.",
  },
  {
    icon: FileBracesCorner,
    title: "How I Think About Code",
    description:
      "For me, coding is about clarity over complexity. Readable structure, simple solutions, and steady improvement matter more than quick fixes.",
  },
];
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <!-- HERO / INTRO -->
  <Section eyebrow='Console.WriteLine("Hello, World!");' align="center" size="lg">
    <div class="text-center">
      <h1 class="text-4xl leading-tight font-bold sm:text-5xl md:text-6xl lg:text-7xl">
        Who <span class="text-accent">I Am</span>
      </h1>

      <div class="mx-auto mt-6 max-w-5xl space-y-6">
        <p class="text-base text-white/70 md:text-lg">
          It started with a simple curiosity about what actually happens <span class="text-accent"
            >“under the hood”</span
          > of a website. Over time, that curiosity turned into a serious commitment. I want to understand
          how modern full-stack applications are built. My goal is to build them on a clean and reliable
          foundation, not just to make them work.
        </p>

        <p class="text-base text-white/70 md:text-lg">
          I don't try to chase every new trend. Instead, I focus on the fundamentals. I want to
          understand how data moves through a system and how the frontend and backend connect. For
          me, development is about steady improvement. Every project helps me think more clearly and
          structure my code better.
        </p>
      </div>
    </div>
  </Section>

  <!-- VALUES -->
  <Section align="center" size="md">
    <div class="text-center">
      <h1 class="text-3xl leading-tight font-bold sm:text-4xl md:text-5xl lg:text-6xl">
        What I <span class="text-accent">Focus </span>On
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-base text-white/70 md:text-lg">
        A few principles that guide how I build and learn.
      </p>
      <div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row"></div>
    </div>

    <Grid cols={3}>
      {values.map((v) => <Card {...v} />)}
    </Grid>
  </Section>
</MainLayout>
