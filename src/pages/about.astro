---
import MainLayout from "../layouts/MainLayout.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Waypoints, Zap, FileBracesCorner } from "lucide-react";
import TechStackGrid from '../components/TechStackGrid.astro';
const values = [
  {
    icon: Waypoints,
    title: "Portfolio Website",
    description:
      "This website is built with Astro, DaisyUI, and TypeScript, with a strong focus on responsive design, clean structure, and a consistent component system.",
  },
  {
    icon: Zap,
    title: "What I'm Working Towards",
    description:
      "I want to become a well-rounded full-stack developer. I aim to design and build applications from the initial idea all the way to deployment. I don't just want things to function. I want to build them cleanly and sustainably.",
  },
  {
    icon: FileBracesCorner,
    title: "How I Think About Code",
    description:
      "For me, coding is about clarity over complexity. Readable structure, simple solutions, and steady improvement matter more than quick fixes.",
  },
];
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section>
			<div class="hero bg-base-200 min-h-[85vh] pt-0">
 				<div class="hero-content text-center">
   					<div class="max-w-5xl px-4">
      					<small  class="text-accent">Console.WriteLine("Hello, World!");</small>
	  						<h1 class="text-7xl font-bold">
								Who <span class="text-accent margin-auto">I Am</span>
							</h1>			
      						<p class="py-5 text-center text-lg max-w-5xl">
								It started with a simple curiosity about what actually happens <span class="text-accent margin-auto">“under the hood”</span> of a website. Over time, that curiosity turned into a serious commitment. I want to understand how modern full-stack applications are built. My goal is to build them on a clean and reliable foundation, not just to make them work.
     						</p>
							    <p class="py-5 text-center text-lg max-w-5xl">
								I don't try to chase every new trend. Instead, I focus on the fundamentals. I want to understand how data moves through a system and how the frontend and backend connect. For me, development is about steady improvement. Every project helps me think more clearly and structure my code better.
     						</p>
    			  </div>
  			  </div>
		    </div>
      </div>
		  <section class="py-24 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
            {values.map((v) => (
            <div class="relative group">
                <!-- DaisyUI Card -->
              <div class="card bg-[#111111] border border-white/10 shadow-sm h-full relative rounded-2xl border border-0.1 border-black hover:border-accent transition-all duration-200">
                <div class="card-body">
                  <div class="w-14 h-14 rounded-xl bg-[#e10600]/10 flex items-center justify-center mb-4">
                    <v.icon className="w-7 h-7 text-[#e10600]" />
                  </div>

                  <h3 class="card-title text-2xl">{v.title}</h3>
                  <p class="text-white/70 leading-relaxed">{v.description}</p>
                  <div class="card-actions justify-end mt-4">
                  </div>
                </div>
              </div>
            </div>
            ))}
          </div>
        </div>
      </section>
        <TechStackGrid />
</section>
</MainLayout>