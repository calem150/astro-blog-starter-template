---
import style from '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_AUTHOR, SITE_DESCRIPTION } from '../consts';
import { Schema } from 'astro:schema';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="hero bg-base-200 min-h-[85vh] pt-0">
 				<div class="hero-content text-center">
   					<div class="max-w-5xl px-4">
      					<small  class="text-accent">&lt;hello world /&gt;</small>
	  						<h1 class="text-7xl font-bold">
								Building <span class="text-accent margin-auto">Digital Experiences</span> with Clean Code
							</h1>			
      						<p class="py-5 text-center text-lg max-w-5xl">
								Junior full-stack developer eager to learn and build modern web applications. Focused on writing clean code and continuously improving my skills in React, TypeScript, and backend development.
     						</p>
							<div class="flex flex-col sm:flex-row justify-center gap-4 mt-8">
							<a class="btn btn-ghost bg-accent border border-accent py-7 p-8 text-1xl" href="/projects">
								View Projects
							</a>

							<a class="btn btn-ghost bg-transparent border border-accent py-7 p-8 text-1xl" href="/contacts">
								Get in Touch
							</a>
</div>
    </div>
  </div>
</div>

			
			<div class="hero min-h-screen bg-base-100">
  			<div class="hero-content text-center">
    		<div class="max-w-5xl">
			<small class="text-accent">&lt;hello world /&gt;</small>
				<h1 class="text-7xl font-bold">
				Building <span class="text-accent">Digital Experiences</span> with Clean Code
				</h1> 
			<p class="max-w-4xl">
				Junior full-stack developer eager to learn and build modern web applications. Focused on writing clean code and continuously improving my skills in React, TypeScript, and backend development.
			</p>
		</div>
		</main>
		<Footer />
	</body>
</html>
