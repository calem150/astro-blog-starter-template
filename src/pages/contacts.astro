---
import Icon from "astro-icon";

interface ContactMethod {
  icon: string;
  label: string;
  value: string;
  href: string;
  description: string;
}

const contactMethods: ContactMethod[] = [
  {
    icon: "lucide:mail",
    label: "Email",
    value: "contact@developer.com",
    href: "mailto:contact@developer.com",
    description: "Best way to reach me for opportunities",
  },
  {
    icon: "lucide:linkedin",
    label: "LinkedIn",
    value: "/in/yourprofile",
    href: "https://linkedin.com/in/yourprofile",
    description: "Let's connect professionally",
  },
  {
    icon: "lucide:github",
    label: "@yourhandle",
    value: "@yourhandle",
    href: "https://github.com/yourhandle",
    description: "Check out my code and projects",
  },
  {
    icon: "lucide:twitter",
    label: "Twitter / X",
    value: "@yourhandle",
    href: "https://twitter.com/yourhandle",
    description: "Follow my dev journey",
  },
];
---

<section class="min-h-screen pt-32 pb-24 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-20">
      <h1 class="text-4xl md:text-6xl font-bold mb-4">
        Let's <span class="text-accent">Connect</span>
      </h1>

      <p class="text-white/70 text-lg max-w-2xl mx-auto">
        I'm open to junior developer positions, internships, and freelance opportunities.
        Feel free to reach out if you'd like to collaborate.
      </p>
    </div>

    <!-- Contact Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20">
      {contactMethods.map((method) => (
        <a
          href={method.href}
          target={method.label !== "Email" ? "_blank" : undefined}
          rel={method.label !== "Email" ? "noopener noreferrer" : undefined}
          class="bg-[#111111] border border-white/5 rounded-xl p-8 hover:border-accent/50 transition-all group"
        >
          <div class="flex items-start gap-4">
            <div class="w-14 h-14 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-accent/20 transition-colors">
              <Icon name={method.icon} class="w-6 h-6 text-accent" />
            </div>

            <div class="flex-1">
              <div class="text-white/60 text-sm mb-1">{method.label}</div>

              <div class="font-bold text-lg mb-2 group-hover:text-accent transition-colors">
                {method.value}
              </div>

              <p class="text-white/60 text-sm">{method.description}</p>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA Section -->
    <div class="bg-gradient-to-br from-[#111111] to-[#1a1a1a] border border-accent/30 rounded-2xl p-8 sm:p-12 text-center">

      <h2 class="text-3xl font-bold mb-4">
        Ready to Work Together?
      </h2>

      <p class="text-white/70 mb-8 max-w-2xl mx-auto leading-relaxed">
        Whether you have a project in mind or want to discuss opportunities —
        I'd love to hear from you.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4">

        <a
          href="mailto:contact@developer.com"
          class="px-8 py-4 bg-accent hover:bg-red-700 text-white rounded-lg font-medium transition-colors inline-flex items-center gap-2"
        >
          <Icon name="lucide:mail" class="w-5 h-5" />
          Send Email
        </a>

        <a
          href="https://linkedin.com/in/yourprofile"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 border-2 border-white/10 hover:border-accent/50 rounded-lg font-medium transition-colors inline-flex items-center gap-2"
        >
          <Icon name="lucide:linkedin" class="w-5 h-5" />
          Connect on LinkedIn
        </a>

      </div>
    </div>

    <!-- Availability -->
    <div class="mt-12 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-[#111111] border border-white/5 rounded-full">
        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
        <span class="text-white/70 text-sm">
          Currently available for opportunities
        </span>
      </div>
    </div>

  </div>
</section>