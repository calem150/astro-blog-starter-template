---
import MainLayout from "../layouts/MainLayout.astro";
import Section from "../components/Section.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { Icon } from "astro-icon/components";

const contactMethods = [
  {
    icon: "lucide:mail",
    label: "Email",
    value: "contact@developer.com",
    href: "mailto:contact@developer.com",
    description: "Best way to reach me for opportunities",
  },
  {
    icon: "lucide:linkedin",
    label: "LinkedIn",
    value: "/in/yourprofile",
    href: "https://linkedin.com/in/yourprofile",
    description: "Let's connect professionally",
  },
  {
    icon: "lucide:github",
    label: "GitHub",
    value: "@yourhandle",
    href: "https://github.com/yourhandle",
    description: "Check out my code and projects",
  },
  {
    icon: "lucide:twitter",
    label: "Twitter / X",
    value: "@yourhandle",
    href: "https://twitter.com/yourhandle",
    description: "Follow my dev journey",
  },
];
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Section title="Contact" subtitle="Choose the method that works best for you." align="center">
    <div class="mb-20 grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        contactMethods.map((method, index) => (
          <a
            href={method.href}
            target={method.label !== "Email" ? "_blank" : undefined}
            rel={method.label !== "Email" ? "noopener noreferrer" : undefined}
            class="contact-card hover:border-accent/50 group rounded-xl border border-white/5 bg-[#111111] p-8 transition-all"
            style={`animation-delay:${index * 100}ms`}
          >
            <div class="flex items-start gap-4">
              <div class="bg-accent/10 group-hover:bg-accent/20 flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-lg transition-colors">
                <Icon name={method.icon} class="text-accent h-6 w-6" />
              </div>

              <div class="flex-1">
                <div class="mb-1 text-sm text-white/60">{method.label}</div>

                <div class="group-hover:text-accent mb-2 text-lg font-bold transition-colors">
                  {method.value}
                </div>

                <p class="text-sm text-white/60">{method.description}</p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </Section>

  <style>
    .contact-card {
      opacity: 0;
      transform: translateY(20px);
      animation: cardIn 500ms ease forwards;
    }

    @keyframes cardIn {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</MainLayout>
