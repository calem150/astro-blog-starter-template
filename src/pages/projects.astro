---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_AUTHOR, SITE_DESCRIPTION } from '../consts';
import { Code2, Zap, Braces } from "lucide-react";
import TechStackGrid from '../components/TechStackGrid.astro';
const featuredProject = {
  title: "Task Manager App",
  description: "A full-stack application for managing tasks and projects.",
  problem: "Users needed a simple way to organize tasks and track progress without the complexity of enterprise tools.",
  solution: "Built a task management app with user authentication, real-time updates, and a responsive UI that works seamlessly across devices.",
  techStack: ["React", "Node.js", "Express", "PostgreSQL"],
  demoLink: "#",
  githubLink: "#",
};
const values = [
  {
    icon: Code2,
    title: "Portfolio Website",
    description:
      "This website. Built with Astro, DaisyUI, and TypeScript. Focus: responsive design, clean structure, component system.",
  },
  {
    icon: Zap,
    title: "Learning by Shipping",
    description:
      "I don't just follow tutorials I build real projects. From UI design to backend logic and deployment, I constantly challenge myself to turn ideas into working products.",
  },
  {
    icon: Braces,
    title: "Growing into Senior Level Thinking",
    description:
      "My goal is not just to write code, but to think like an engineer. I study system design, security, and software architecture to grow beyond junior level step by step, project by project.Leveraging cutting-edge technologies to build reliable, future-proof web applications.",
  },
];
const otherProjects = [
  {
    title: "Weather Dashboard",
    description:
      "Weather app showing current conditions and forecasts.",
    tags: ["Astro", "API", "Tailwind"],
    githubLink: "#",
  },
  {
    title: "Blog Platform",
    description:
      "Simple blog platform with markdown support.",
    tags: ["Next.js", "TypeScript", "MongoDB"],
    githubLink: "#",
  },
  {
    title: "E-Commerce Demo",
    description:
      "Basic e-commerce site with product listings.",
    tags: ["React", "Node.js", "Stripe"],
    githubLink: "#",
  },
];

const learnings = [
  {
    category: "Architecture & Planning",
    title: "Structure Early, Save Later",
    description:
      "Starting with a clear folder structure and component hierarchy prevents technical debt.",
    icon: "🏗️",
  },
  {
    category: "Development Philosophy",
    title: "Simplicity Over Cleverness",
    description:
      "Clean, readable code beats clever one-liners.",
    icon: "✨",
  },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
<section class="min-h-screen pt-32 pb-24 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-20">
      <small  class="text-accent">console.log("Hello, World!");</small>
      <h1 class="text-4xl md:text-6xl font-bold mb-4">
        Selected <span class="text-accent">Projects</span>
      </h1>
      <p class="text-white/70 max-w-2xl mx-auto text-lg">
        A selection of projects that shaped my growth as a full-stack developer.
      </p>
    </div>

    <!-- Featured Project -->
    <div class="bg-[#111111] border border-white/5 rounded-2xl p-6 sm:p-8 md:p-12 mb-20">
      <h2 class="text-3xl font-bold mb-3">{featuredProject.title}</h2>
      <p class="text-white/70 mb-8">{featuredProject.description}</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
        <div>
          <h3 class="text-accent font-bold mb-3 text-sm uppercase tracking-wider">
            Problem
          </h3>
          <p class="text-white/70 text-sm leading-relaxed">
            {featuredProject.problem}
          </p>
        </div>

        <div>
          <h3 class="text-accent font-bold mb-3 text-sm uppercase tracking-wider">
            Solution
          </h3>
          <p class="text-white/70 text-sm leading-relaxed">
            {featuredProject.solution}
          </p>
        </div>

        <div>
          <h3 class="text-accent font-bold mb-3 text-sm uppercase tracking-wider">
            Tech Stack
          </h3>

          <div class="flex flex-wrap gap-2">
            {featuredProject.techStack.map((tech) => (
              <span class="px-3 py-1.5 bg-[#1a1a1a] border border-white/10 rounded-md text-sm">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-4">
        <a
          href={featuredProject.demoLink}
          class="inline-flex items-center gap-2 px-6 py-3 bg-accent hover:bg-red-700 text-white rounded-lg font-medium transition-colors"
        >
          Live Demo
        </a>

        <a
          href={featuredProject.githubLink}
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-white/10 hover:border-accent/50 rounded-lg font-medium transition-colors"
        >
          GitHub
        </a>
      </div>
    </div>

    <!-- Other Projects -->
    <h2 class="text-2xl font-bold mb-8">Other Projects</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-32">
      {otherProjects.map((project) => (
        <div class="bg-[#111111] border border-white/5 rounded-xl p-6 hover:border-accent/30 transition-colors">
          <h3 class="text-xl font-bold mb-3">{project.title}</h3>
          <p class="text-white/70 text-sm mb-4 leading-relaxed">
            {project.description}
          </p>

          <div class="flex flex-wrap gap-2 mb-4">
            {project.tags.map((tag) => (
              <span class="px-3 py-1 bg-[#1a1a1a] border border-white/10 rounded-md text-xs">
                {tag}
              </span>
            ))}
          </div>

          <a
            href={project.githubLink}
            class="inline-flex items-center gap-2 text-accent hover:text-red-600 font-medium text-sm transition-colors"
          >
            Full Code
          </a>
        </div>
      ))}
    </div>

    <!-- Continuous Improvement -->
    <h2 class="text-3xl md:text-4xl font-bold mb-4">
      Continuous <span class="text-accent">Improvement</span>
    </h2>

    <p class="text-white/70 mb-8">
      Real insights from building projects and refining systems.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {learnings.map((learning) => (
        <div class="bg-[#111111] border border-white/5 rounded-xl p-6 hover:border-accent/30 transition-colors">
          <div class="flex items-start gap-4">
            <div class="text-3xl">{learning.icon}</div>

            <div>
              <div class="text-accent text-xs font-bold uppercase tracking-wider mb-2">
                {learning.category}
              </div>

              <h3 class="font-bold text-lg mb-2">
                {learning.title}
              </h3>

              <p class="text-white/70 text-sm leading-relaxed">
                {learning.description}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
      <TechStackGrid />
		</main>
		  <Footer />
    </div>
	</body>
</html>
