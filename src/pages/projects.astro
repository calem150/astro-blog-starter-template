---
import MainLayout from "../layouts/MainLayout.astro";
import Section from "../components/Section.astro";
import Grid from "../components/Grid.astro";
import Card from "../components/Card.astro";
import Badge from "../components/Badge.astro";
import Button from "../components/Button.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import TechStackGrid from "../components/TechStackGrid.astro";
import { Icon } from "astro-icon/components";

const featuredProject = {
  title: "Task Manager App",
  description: "A full-stack application for managing tasks and projects.",
  problem:
    "Users needed a simple way to organize tasks and track progress without the complexity of enterprise tools.",
  solution:
    "Built a task management app with user authentication, real-time updates, and a responsive UI that works seamlessly across devices.",
  techStack: ["React", "Node.js", "Express", "PostgreSQL"],
  demoLink: "#",
  githubLink: "#",
};

const otherProjects = [
  {
    title: "Weather Dashboard",
    description: "Weather app showing current conditions and forecasts.",
    tags: ["Astro", "API", "Tailwind"],
    demoLink: "#",
    githubLink: "#",
  },
  {
    title: "Blog Platform",
    description: "Simple blog platform with markdown support.",
    tags: ["Next.js", "TypeScript", "MongoDB"],
    demoLink: "#",
    githubLink: "#",
  },
  {
    title: "E-Commerce Demo",
    description: "Basic e-commerce site with product listings.",
    tags: ["React", "Node.js", "Stripe"],
    demoLink: "#",
    githubLink: "#",
  },
];

const learnings = [
  {
    category: "Debugging",
    title: "Read the error first",
    description:
      "Most bugs become clear after carefully reading the error message and the stack trace.",
    icon: "lucide:bug",
  },
  {
    category: "Performance",
    title: "Fast pages matter",
    description:
      "Optimizing bundle size and loading speed improves the user experience.",
    icon: "lucide:gauge",
  },
  {
    category: "Problem Solving",
    title: "Break problems into smaller parts",
    description:
      "Complex features become easier when divided into small manageable tasks.",
    icon: "lucide:puzzle",
  },
  {
    category: "Learning Mindset",
    title: "Build projects to understand tools",
    description:
      "The best way to learn new technologies is by building real projects.",
    icon: "lucide:book-open",
  },
];
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <!-- HERO -->

  <Section eyebrow='console.log("Hello, World!")' align="center" size="lg">
    <div class="text-center">
      <h1
        class="text-3xl leading-tight font-bold sm:text-4xl md:text-5xl lg:text-6xl"
      >
        Selected <span class="text-accent">Projects</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-base text-white/70 md:text-lg">
        A selection of projects that shaped my growth as a full-stack developer.
      </p>

      <div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row"></div>
    </div>
  </Section>
  <!-- FEATURED PROJECT -->
  <Section align="left">
    <dev class="text-center">
      <h2
        class="pb-4 text-3xl leading-tight font-bold sm:text-4xl md:text-3xl lg:text-5xl"
      >
        Featured <span class="text-accent">Projects </span>
      </h2>
    </dev>

    <div
      class="hover:border-accent rounded-2xl border border-white/5 bg-[#111111] p-6 md:p-10"
    >
      <h2 class="mb-4 text-3xl font-bold">
        {featuredProject.title}
      </h2>

      <p class="mb-8 text-white/70">
        {featuredProject.description}
      </p>

      <Grid cols={3}>
        <div>
          <h3 class="text-accent mb-2 text-sm font-bold uppercase">Problem</h3>

          <p class="text-sm text-white/70">
            {featuredProject.problem}
          </p>
        </div>

        <div>
          <h3 class="text-accent mb-2 text-sm font-bold uppercase">Solution</h3>

          <p class="text-sm text-white/70">
            {featuredProject.solution}
          </p>
        </div>

        <div>
          <h3 class="text-accent mb-2 text-sm font-bold uppercase">
            Tech Stack
          </h3>

          <div class="mt-2 flex flex-wrap gap-2">
            {featuredProject.techStack.map((tech) => <Badge>{tech}</Badge>)}
          </div>
        </div>
      </Grid>

      <div class="mt-8 flex flex-wrap gap-4">
        <Button href={featuredProject.demoLink} variant="primary">
          Live Demo
        </Button>

        <Button href={featuredProject.githubLink} variant="ghost">
          Source Code
        </Button>
      </div>
    </div>
  </Section>

  <!-- OTHER PROJECTS -->
  <Section
    title="Other Projects"
    subtitle="Smaller experiments and learning projects."
    align="center"
  >
    <Grid cols={3}>
      {
        otherProjects.map((project) => (
          <Card title={project.title} description={project.description}>
            <div slot="footer" class="mb-3 flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <Badge>{tag}</Badge>
              ))}
            </div>

            <div slot="actions" class="flex gap-3">
              <Button href={project.demoLink}>Live Demo</Button>

              <Button href={project.githubLink} variant="secondary">
                Source Code
              </Button>
            </div>
          </Card>
        ))
      }
    </Grid>
  </Section>

  <!-- LEARNINGS -->
  <Section
    title="Continuous Improvement"
    subtitle="Real insights from building projects and refining systems."
    align="center"
  >
    <Grid cols={2}>
      {
        learnings.map((learning) => (
          <div class="flex gap-4 rounded-xl border border-white/5 bg-[#111111] p-6">
            <Icon name={learning.icon} class="text-accent h-8 w-8" />

            <div>
              <div class="text-accent mb-1 text-xs font-bold uppercase">
                {learning.category}
              </div>

              <h3 class="mb-1 font-semibold">{learning.title}</h3>

              <p class="text-sm text-white/70">{learning.description}</p>
            </div>
          </div>
        ))
      }
    </Grid>
  </Section>

  <TechStackGrid />
</MainLayout>
