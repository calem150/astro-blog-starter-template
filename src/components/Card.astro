---
const { icon: Icon, title, description, href } = Astro.props;
---

<div
  class="card hover:border-accent h-full rounded-2xl border border-white/10 bg-[#111111] transition"
>
  <div class="card-body">
    {
      Icon && (
        <div class="bg-accent/10 mb-4 flex h-14 w-14 items-center justify-center rounded-xl">
          <Icon class="text-accent h-7 w-7" />
        </div>
      )
    }

    {title && <h3 class="text-xl font-semibold md:text-2xl">{title}</h3>}

    {description && <p class="text-sm leading-relaxed text-white/70 md:text-base">{description}</p>}

    {
      href && (
        <div class="mt-4">
          <a href={href} class="text-accent text-sm hover:underline">
            Learn more →
          </a>
        </div>
      )
    }
  </div>
</div>
