---
interface Props {
  title?: any;
  subtitle?: string;
  eyebrow?: string;
  align?: "left" | "center";
  size?: "sm" | "md" | "lg";
}

const { title, subtitle, eyebrow, align = "left", size = "md" } = Astro.props as Props;

const alignClasses = align === "center" ? "text-center" : "text-left";
const subtitleAlign = align === "center" ? "mx-auto" : "";

const sizeMap = {
  sm: {
    wrap: "py-12 md:py-16",
    title: "text-2xl sm:text-3xl md:text-4xl",
    subtitle: "text-base md:text-lg",
  },
  md: {
    wrap: "py-16 md:py-24",
    title: "text-3xl sm:text-4xl md:text-5xl",
    subtitle: "text-base md:text-lg",
  },
  lg: {
    wrap: "py-20 md:py-28",
    title: "text-4xl sm:text-5xl md:text-6xl",
    subtitle: "text-lg md:text-xl",
  },
};

const s = sizeMap[size];
---

<section class={s.wrap}>
  <div class={`mx-auto max-w-6xl px-4 sm:px-6 ${alignClasses}`}>
    {eyebrow && <small class="text-accent mb-2 block">{eyebrow}</small>}

    {title && <h2 class={`leading-tight font-bold ${s.title}`}>{title}</h2>}

    {
      subtitle && (
        <p class={`mt-4 max-w-2xl text-white/70 ${subtitleAlign} ${s.subtitle}`}>{subtitle}</p>
      )
    }

    <div class="mt-10">
      <slot />
    </div>
  </div>
</section>
