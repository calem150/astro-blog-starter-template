---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
}

const { href, variant = "primary" } = Astro.props as Props;

const variants = {
  primary: "border border-accent text-accent hover:bg-accent hover:text-black",
  secondary:
    "border border-white/20 text-white hover:border-accent hover:text-accent",
  ghost: "border-transparent text-white hover:text-accent",
};

const style = variants[variant];
---

<a href={href} class={`btn px-6 py-3 text-sm md:text-base transition ${style}`}>
  <slot />
</a>
