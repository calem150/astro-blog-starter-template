---
import Scrolltop from "../components/Scrolltop.astro";

const path = Astro.url.pathname;

const links = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Projects", href: "/projects" },
  { name: "Contact", href: "/contacts" },
];
---

<Scrolltop />

<div class="drawer">
  <input id="nav-drawer" type="checkbox" class="drawer-toggle" />

  <!-- ======================= -->
  <!-- CONTENT -->
  <!-- ======================= -->

  <div class="drawer-content">
    <header
      id="navbar"
      class="navbar border-base-300 bg-base-100/80 sticky top-0 z-50 border-b px-4 backdrop-blur"
    >
      <!-- Glow line -->

      <div
        id="navbar-glow"
        class="h-1px pointer-events-none absolute bottom-0 left-0 w-full opacity-0 transition-opacity duration-500"
      >
        <div
          class="via-accent mx-auto h-full max-w-7xl bg-linear-to-r from-transparent to-transparent blur-sm"
        >
        </div>
      </div>

      <!-- Logo -->

      <div class="navbar-start">
        <a
          href="/"
          class="btn btn-ghost hover:border-accent flex items-center gap-0 rounded border border-transparent"
        >
          <span class="text-accent text-xl">&lt;Dev</span>
          <span class="text-base-content text-xl">/&gt;</span>
        </a>
      </div>

      <!-- Center text -->

      <div class="navbar-center hidden md:flex">
        <span class="text-base-content/60 text-sm">
          Alpha Version · Placeholder content
        </span>
      </div>

      <!-- Desktop Navigation -->

      <div class="navbar-end hidden items-center gap-2 lg:flex">
        <ul class="menu menu-horizontal gap-1">
          {
            links.map((link) => {
              const active = path === link.href;

              return (
                <li>
                  <a
                    href={link.href}
                    class:list={[
                      "group relative px-3 transition",
                      "hover:text-accent",
                      active && "text-accent font-semibold",
                    ]}
                  >
                    {link.name}

                    <span
                      class:list={[
                        "bg-accent h-2px absolute bottom-0 left-0 rounded transition-all duration-300",
                        active ? "w-full" : "w-0 group-hover:w-full",
                      ]}
                    />
                  </a>
                </li>
              );
            })
          }
        </ul>

        <!-- Language -->

        <div class="join mr-2 gap-1">
          <a
            href="/"
            class:list={[
              "btn btn-sm join-item text-accent bg-transparent",
              !path.startsWith("/de") ? "btn-accent" : "btn-ghost",
            ]}
          >
            EN
          </a>

          <a
            href="/de"
            class:list={[
              "btn btn-sm join-item text-accent border-accent bg-transparent",
              path.startsWith("/de") ? "btn-accent" : "btn-ghost",
            ]}
          >
            DE
          </a>
        </div>

        <!-- Theme Dropdown -->
        <label class="swap swap-rotate">
          <!-- Theme toggle -->
          <input type="checkbox" class="theme-controller" value="synthwave" />

          <!-- Sun (Light Mode) -->
          <svg
            class="swap-off h-10 w-10 fill-current"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
          >
            <path
              d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"
            ></path>
          </svg>

          <!-- Moon (Dark Mode) -->
          <svg
            class="swap-on h-10 w-10 fill-current"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
          >
            <path
              d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"
            ></path>
          </svg>
        </label>

        <!-- Mobile button -->

        <div class="navbar-end lg:hidden">
          <label for="nav-drawer" class="btn btn-ghost">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </label>
        </div>
      </div>

      <!-- ======================= -->
      <!-- MOBILE DRAWER -->
      <!-- ======================= -->

      <div class="drawer-side z-100">
        <label for="nav-drawer" class="drawer-overlay"></label>

        <aside class="menu bg-base-100 min-h-full w-72 p-6">
          <div class="text-accent mb-6 text-lg font-bold">Navigation</div>

          {
            links.map((link) => {
              const active = path === link.href;

              return (
                <li>
                  <a
                    href={link.href}
                    data-close-drawer
                    class:list={[
                      "text-base transition",
                      "hover:text-accent",
                      active && "text-accent font-semibold",
                    ]}
                  >
                    {link.name}
                  </a>
                </li>
              );
            })
          }

          <div class="divider"></div>

          <!-- Language -->

          <div class="flex gap-2">
            <a
              href="/"
              class:list={[
                "btn btn-sm",
                !path.startsWith("/de") ? "btn-accent" : "btn-ghost",
              ]}
            >
              EN
            </a>

            <a
              href="/de"
              class:list={[
                "btn btn-sm",
                path.startsWith("/de") ? "btn-accent" : "btn-ghost",
              ]}
            >
              DE
            </a>
          </div>

          <div class="divider"></div>

          <!-- ======================= -->
          <!-- COMMAND PALETTE -->
          <!-- ======================= -->

          <dialog id="command_palette" class="modal">
            <div class="modal-box">
              <h3 class="mb-4 text-lg font-bold">Quick Navigation</h3>

              <ul class="menu">
                {
                  links.map((link) => (
                    <li>
                      <a href={link.href}>{link.name}</a>
                    </li>
                  ))
                }
              </ul>

              <div class="modal-action">
                <form method="dialog">
                  <button class="btn"> Close </button>
                </form>
              </div>
            </div>
          </dialog>

          <script is:inline>
            // Theme system

            document.addEventListener("DOMContentLoaded", () => {
              const toggle = document.querySelector(".theme-controller");
              const saved = localStorage.getItem("theme");

              if (saved === "black") {
                toggle.checked = true;
              }

              toggle.addEventListener("change", () => {
                const theme = toggle.checked ? "black" : "light";

                localStorage.setItem("theme", theme);
                document.documentElement.setAttribute("data-theme", theme);
              });
            });
            const saved = localStorage.getItem("theme");

            if (saved) {
              setTheme(saved);
            } else {
              const prefersDark = window.matchMedia(
                "(prefers-color-scheme: dark)",
              ).matches;

              setTheme(prefersDark ? "black" : "light");
            }

            // Drawer close

            document.querySelectorAll("[data-close-drawer]").forEach((link) => {
              link.addEventListener("click", () => {
                document.getElementById("nav-drawer").checked = false;
              });
            });

            // Command palette

            document.addEventListener("keydown", (e) => {
              if ((e.metaKey || e.ctrlKey) && e.key === "k") {
                e.preventDefault();

                document.getElementById("command_palette").showModal();
              }
            });

            // Navbar glow

            const navbarGlow = document.getElementById("navbar-glow");

            const handleNavbarGlow = () => {
              if (!navbarGlow) return;

              if (window.scrollY > 40) {
                navbarGlow.classList.remove("opacity-0");
                navbarGlow.classList.add("opacity-100");
              } else {
                navbarGlow.classList.remove("opacity-100");
                navbarGlow.classList.add("opacity-0");
              }
            };

            window.addEventListener("scroll", handleNavbarGlow, {
              passive: true,
            });

            handleNavbarGlow();
          </script>
        </aside>
      </div>
    </header>
  </div>
</div>
