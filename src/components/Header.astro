---
import Scrolltop from "../components/Scrolltop.astro";
---

<Scrolltop />

<header class="navbar bg-base-100 sticky top-0 z-50 px-3 shadow-sm md:px-6">
  <!-- Logo -->
  <div class="navbar-start">
    <a href="/" class="btn btn-ghost hover:border-accent flex items-center gap-0 rounded border">
      <span class="text-accent text-xl">&lt;Dev</span>
      <span class="text-xl text-white">/&gt;</span>
    </a>
  </div>

  <!-- Center message -->
  <div class="navbar-center hidden md:flex">
    <span class="text-center text-xs text-white/70 md:text-sm">
      Alpha Version. All data shown is placeholder content.
    </span>
  </div>

  <!-- Navigation -->
  <div class="navbar-end">
    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex">
      <ul class="menu menu-horizontal gap-2 px-1">
        <li><a class="link link-hover hover:text-accent" href="/">Home</a></li>
        <li><a class="link link-hover hover:text-accent" href="/about">About</a></li>
        <li><a class="link link-hover hover:text-accent" href="/projects">Projects</a></li>
        <li><a class="link link-hover hover:text-accent" href="/contacts">Contact</a></li>
      </ul>
    </nav>

    <!-- Mobile Menu -->
    <div class="dropdown dropdown-end lg:hidden">
      <button tabindex="0" class="btn btn-ghost">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <ul
        tabindex="0"
        class="menu menu-sm dropdown-content bg-base-100 rounded-box z-[1] mt-3 w-56 p-2 shadow"
      >
        <li><a class="hover:text-accent" href="/">Home</a></li>
        <li><a class="hover:text-accent" href="/about">About</a></li>
        <li><a class="hover:text-accent" href="/projects">Projects</a></li>
        <li><a class="hover:text-accent" href="/contacts">Contact</a></li>
      </ul>
    </div>
  </div>
</header>
