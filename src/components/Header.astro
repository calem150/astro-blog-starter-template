---
import Scrolltop from "../components/Scrolltop.astro";
---
<Scrolltop />
<div class="navbar bg-base-100 shadow-sm sticky top-0 z-50 relative">
  <div class="navbar-start">
    <a href="/" class="btn btn-ghost flex items-center gap-0 border hover:border-accent rounded">
      <span class="text-xl text-accent">&lt;Dev</span>
      <span class="text-xl text-white">/&gt;</span>
    </a>
  </div>

  <div class="navbar-end">
    {/* Desktop */}
    <div class="hidden lg:flex">
      <ul class="menu menu-horizontal px-1">
        <li><a class="link link-hover hover:text-accent" href="/">Home</a></li>
        <li><a class="link link-hover hover:text-accent" href="/about">About</a></li>
        <li><a class="link link-hover hover:text-accent" href="/projects">Projects</a></li>
        <li><a class="link link-hover hover:text-accent" href="/contact">Contact</a></li>
      </ul>
    </div>

    {/* Mobile */}
<div class="relative lg:hidden">
  <button id="mobileMenuBtn" class="btn btn-ghost">
    <svg xmlns="http://www.w3.org/2000/svg" 
         class="h-6 w-6" 
         fill="none" 
         viewBox="0 0 24 24" 
         stroke="currentColor">
      <path stroke-linecap="round" 
            stroke-linejoin="round" 
            stroke-width="2" 
            d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>

  <div id="mobileMenu"
       class="absolute right-0 mt-2 w-48 bg-base-200 border border-base-300 rounded-box shadow-lg opacity-0 pointer-events-none transition-all duration-200 z-50">
    <ul class="menu p-2 text-lg">
      <li><a href="/">Home</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/projects">Projects</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
  </div>
</div>

<script is:inline>
  const btn = document.getElementById("mobileMenuBtn");
  const menu = document.getElementById("mobileMenu");

  btn.addEventListener("click", () => {
    menu.classList.toggle("opacity-0");
    menu.classList.toggle("pointer-events-none");
  });
</script>