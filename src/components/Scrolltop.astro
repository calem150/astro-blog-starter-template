---
// src/components/Scrolltop.astro
// Usage: <Scrolltop />
---

<a
  href="#top"
  id="scrollTopBtn"
  aria-label="Back to top"
  class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-base-200 border border-base-300 rounded-full shadow-lg flex items-center justify-center hover:bg-primary/10 transition-all opacity-0 pointer-events-none"
>
  <img
    src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/archlinux/archlinux-plain.svg"
    alt=""
    class="w-8 h-8 invert brightness-200"
    loading="lazy"
  />
</a>

<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("scrollTopBtn");
    if (!btn) return;

    const toggle = () => {
      if (window.scrollY > 300) {
        btn.classList.remove("opacity-0", "pointer-events-none");
        btn.classList.add("opacity-100");
      } else {
        btn.classList.add("opacity-0", "pointer-events-none");
        btn.classList.remove("opacity-100");
      }
    };

    toggle();
    window.addEventListener("scroll", toggle, { passive: true });
  });
</script>

<style>
  /* Optional: smooth scroll globally, falls du es nicht schon hast */
  :global(html) {
    scroll-behavior: smooth;
  }
</style>