---
// src/components/Scrolltop.astro
// Usage: <Scrolltop />
---

<a
  href="#top"
  id="scrollTopBtn"
  aria-label="Back to top"
  class="sm:hover:border-accent active:border-accent focus-visible:ring-accent pointer-events-none fixed right-6 bottom-6 z-50 flex h-14 w-14 items-center justify-center rounded-full border border-white opacity-0 shadow-lg transition-all focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-black focus-visible:outline-none active:scale-95"
>
  <img
    src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/archlinux/archlinux-plain.svg"
    alt=""
    class="h-8 w-8 brightness-200 invert"
    loading="lazy"
  />
</a>

<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("scrollTopBtn");
    if (!btn) return;

    const toggle = () => {
      if (window.scrollY > 300) {
        btn.classList.remove("opacity-0", "pointer-events-none");
        btn.classList.add("opacity-100");
      } else {
        btn.classList.add("opacity-0", "pointer-events-none");
        btn.classList.remove("opacity-100");
      }
    };

    toggle();
    window.addEventListener("scroll", toggle, { passive: true });
  });
</script>

<style>
  /* Optional: smooth scroll globally, falls du es nicht schon hast */
  :global(html) {
    scroll-behavior: smooth;
  }
</style>
