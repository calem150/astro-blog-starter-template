---
const techStack = [
  {
    category: "Frontend",
    items: [
      {
        name: "Astro",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg",
        url: "https://astro.build/",
      },
      {
        name: "React",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg",
        url: "https://react.dev/",
      },
      {
        name: "Tailwind",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tailwindcss/tailwindcss-original.svg",
        url: "https://tailwindcss.com/",
      },
      {
        name: "TypeScript",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg",
        url: "https://www.typescriptlang.org/",
      },
    ],
  },

  {
    category: "Backend",
    items: [
      {
        name: "Node.js",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-original.svg",
        url: "https://nodejs.org/",
      },

      {
        name: "Hono",
        logo: `<svg viewBox="0 0 24 24" fill="#E36002">
          <path d="M12.445.002a45.529 45.529 0 0 0-5.252 8.146 8.595 8.595 0 0 1-.555-.53 27.796 27.796 0 0 0-1.205-1.542 8.762 8.762 0 0 0-1.251 2.12 20.743 20.743 0 0 0-1.448 5.88 8.867 8.867 0 0 0 .338 3.468c1.312 3.48 3.794 5.593 7.445 6.337 3.055.438 5.755-.333 8.097-2.312 2.677-2.59 3.359-5.634 2.047-9.132a33.287 33.287 0 0 0-2.988-5.59A91.34 91.34 0 0 0 12.615.053a.216.216 0 0 0-.17-.051Zm-.336 3.906a50.93 50.93 0 0 1 4.794 6.552c.448.767.817 1.57 1.108 2.41.606 2.386-.044 4.354-1.951 5.904-1.845 1.298-3.87 1.683-6.072 1.156-2.376-.737-3.75-2.335-4.121-4.794a5.107 5.107 0 0 1 .242-2.266c.358-.908.79-1.774 1.3-2.601l1.446-2.121a397.33 397.33 0 0 0 3.254-4.24Z"/>
          </svg>`,
        url: "https://hono.dev/",
      },

      {
        name: "PostgreSQL",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg",
        url: "https://www.postgresql.org/",
      },

      {
        name: "MongoDB",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mongodb/mongodb-original.svg",
        url: "https://www.mongodb.com/",
      },
    ],
  },

  {
    category: "Tools",
    items: [
      {
        name: "Git",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg",
        url: "https://git-scm.com/",
      },
      {
        name: "GitHub",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg",
        url: "https://github.com/calem150",
      },
      {
        name: "Bun",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bun/bun-original.svg",
        url: "https://bun.sh/",
      },
      {
        name: "Cloudflare",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/cloudflare/cloudflare-original.svg",
        url: "https://www.cloudflare.com/",
      },
    ],
  },
];
---

<section class="px-6 py-24">
  <div class="mx-auto max-w-7xl">
    <!-- Heading -->

    <div class="mb-16 text-center">
      <h2 class="mb-4 text-4xl font-bold md:text-5xl">
        Tech <span class="text-accent">Stack</span>
      </h2>

      <p class="text-base-content/70">
        Technologies I work with and continue to learn
      </p>
    </div>

    <!-- Grid -->

    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {
        techStack.map((group) => (
          <div class="card hover:border-accent border border-transparent bg-[#111111] transition">
            <div class="card-body">
              <h3 class="card-title text-accent mb-4">{group.category}</h3>

              <div class="space-y-4">
                {group.items.map((tech) => (
                  <a
                    href={tech.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-center gap-4 transition hover:scale-[1.02]"
                  >
                    <div class="group-hover:bg-accent/10 flex h-10 w-10 items-center justify-center rounded-lg bg-[#3a3a3a] transition">
                      {tech.logo.startsWith("<svg") ? (
                        <span
                          class="h-6 w-6 text-white opacity-70 transition group-hover:opacity-100"
                          set:html={tech.logo}
                        />
                      ) : (
                        <img
                          src={tech.logo}
                          alt={tech.name}
                          class="h-6 w-6 object-contain opacity-70 transition group-hover:opacity-100"
                        />
                      )}
                    </div>

                    <span class="group-hover:text-accent font-medium transition">
                      {tech.name}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
