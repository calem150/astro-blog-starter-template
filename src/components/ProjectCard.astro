---
const { title, description, tech = [], demo, github } = Astro.props;
---

<div
  class="card hover:border-accent h-full rounded-2xl border border-white/10 bg-[#111111] transition"
>
  <div class="card-body">
    <h3 class="text-xl font-semibold md:text-2xl">
      {title}
    </h3>

    <p class="text-sm leading-relaxed text-white/70 md:text-base">
      {description}
    </p>

    {
      tech.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tech.map((t: string) => (
            <span class="rounded-md border border-white/10 bg-[#1a1a1a] px-3 py-1 text-xs">
              {t}
            </span>
          ))}
        </div>
      )
    }

    <div class="mt-5 flex gap-3">
      {
        demo && (
          <a
            href={demo}
            target="_blank"
            rel="noreferrer"
            class="btn border-accent text-accent hover:bg-accent border px-4 py-2 text-xs transition hover:text-black md:text-sm"
          >
            Live Demo
          </a>
        )
      }

      {
        github && (
          <a
            href={github}
            target="_blank"
            rel="noreferrer"
            class="btn hover:border-accent hover:text-accent border border-white/20 px-4 py-2 text-xs text-white transition md:text-sm"
          >
            Source Code
          </a>
        )
      }
    </div>
  </div>
</div>
