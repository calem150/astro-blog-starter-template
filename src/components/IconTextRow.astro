---
const { icon: Icon, title, description, href } = Astro.props;
---

<div class="flex items-start gap-4">
  {
    Icon && (
      <div class="bg-accent/10 flex h-10 w-10 items-center justify-center rounded-lg">
        <Icon class="text-accent h-5 w-5" />
      </div>
    )
  }

  <div>
    {title && <h3 class="text-lg font-semibold">{title}</h3>}

    {description && <p class="text-sm text-white/70">{description}</p>}

    {
      href && (
        <a href={href} class="text-accent text-sm hover:underline">
          {href}
        </a>
      )
    }
  </div>
</div>
